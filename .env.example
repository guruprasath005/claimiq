# ── Primary LLM — local vllm serving Gemma 4 12B ─────────────────────────────
OPENAI_API_KEY=none
OPENAI_BASE_URL=http://10.10.116.160:11632/v1
LLM_MODEL=gemma-4-12b-it

# ── Fallback — GPT-4o-mini (used when Gemma is unreachable) ──────────────────
FALLBACK_API_KEY=sk-...your-openai-key...
FALLBACK_MODEL=gpt-4o-mini

# ── Indexer (same vllm endpoint by default) ───────────────────────────────────
INDEX_MODEL_URL=http://10.10.116.160:11632/v1
INDEX_MODEL=gemma-4-12b-it

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/claimiq

# ── CORS (add your frontend origin) ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Optional ──────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...   # alternative router for cloud models
